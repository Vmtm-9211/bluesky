APP_NAME=Company Expense Tracking Dashboard
ENVIRONMENT=local
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./expense_dashboard.db
FRONTEND_URL=http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=finance-alerts@bilvantis.com
SMTP_TLS=true

FINANCE_ADMIN_EMAIL=admin@bilvantis.com

# ── Vertex AI / GCP ─────────────────────────────────────────────────────────
# Set VERTEX_ENABLED=true to use Gemini for receipt analysis
VERTEX_ENABLED=false

GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west4
VERTEX_MODEL=gemini-2.5-flash

GCP_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com
WIF_PROVIDER=projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL_ID/providers/PROVIDER_ID

# Path to the WIF credential config JSON (generated by gcloud or auto-created)
GOOGLE_CREDENTIALS_FILE=credentials/wif-config.json
